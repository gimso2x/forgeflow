{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AdapterManifest",
  "type": "object",
  "required": [
    "name",
    "runtime_type",
    "input_mode",
    "output_mode",
    "supports_roles",
    "supports_generated_files",
    "tooling_constraints",
    "generated_filename",
    "recommended_location",
    "surface_style",
    "handoff_format"
  ],
  "properties": {
    "name": {"type": "string"},
    "runtime_type": {"type": "string"},
    "input_mode": {"type": "string"},
    "output_mode": {"type": "string"},
    "supports_roles": {"type": "array", "items": {"type": "string"}},
    "supports_generated_files": {"type": "boolean"},
    "tooling_constraints": {"type": "array", "items": {"type": "string"}},
    "generated_filename": {"type": "string"},
    "recommended_location": {"type": "string"},
    "surface_style": {"type": "string"},
    "handoff_format": {"type": "string"}
  },
  "additionalProperties": false
}