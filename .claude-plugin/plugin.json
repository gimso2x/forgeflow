{
  "name": "forgeflow",
  "version": "2.1.0",
  "description": "Artifact-first delivery workflow for Claude Code: clarify, plan, execute, review, ship through markdown artifacts",
  "author": {
    "name": "gimso2x",
    "url": "https://github.com/gimso2x"
  },
  "repository": "https://github.com/gimso2x/forgeflow",
  "license": "MIT",
  "keywords": [
    "ai-agents",
    "workflow",
    "artifacts",
    "claude-code",
    "codex",
    "cursor"
  ],
  "interface": {
    "defaultPrompt": [
      "/forgeflow:clarify <describe the coding task>",
      "/forgeflow:ff-plan",
      "/forgeflow:execute",
      "/forgeflow:ff-review",
      "/forgeflow:ship",
      "/forgeflow:long-run",
      "/forgeflow:benchmark",
      "/forgeflow:ff-config",
      "/forgeflow:ff-loop <describe the coding task>",
      "/forgeflow:status",
      "/forgeflow:qa <artifact path>",
      "/forgeflow:unstuck"
    ]
  }
}
