{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "gates"],
  "properties": {
    "version": {"type": ["string", "number"]},
    "gates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requires"],
        "properties": {
          "requires": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "review_type": {"type": "string", "enum": ["spec", "quality"]},
          "verdict": {"type": "string", "enum": ["approved"]},
          "run_state_flags": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}