{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanLedger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "route",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large_high_risk"
      ]
    },
    "current_task_id": {
      "type": "string",
      "minLength": 1
    },
    "contracts_ref": {
      "type": "string",
      "minLength": 1
    },
    "last_review_verdict": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "blocked"
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "depends_on",
          "files",
          "parallel_safe",
          "status",
          "required_gates",
          "evidence_refs",
          "attempt_count"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "parallel_safe": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "done",
              "blocked",
              "cancelled"
            ]
          },
          "required_gates": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "machine",
                "validator",
                "scenario",
                "human"
              ]
            },
            "uniqueItems": true
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "attempt_count": {
            "type": "integer",
            "minimum": 0
          },
          "blocked_reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "blocked"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "required": [
                "blocked_reason"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "const": "done"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "evidence_refs": {
                  "minItems": 1
                },
                "required_gates": {
                  "minItems": 1
                }
              }
            }
          }
        ]
      }
    },
    "completed_stages": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "clarify",
          "plan",
          "execute",
          "spec-review",
          "quality-review",
          "finalize",
          "long-run"
        ]
      },
      "uniqueItems": true
    },
    "completed_gates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "retries": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "clarify",
          "plan",
          "execute",
          "spec-review",
          "quality-review",
          "finalize",
          "long-run"
        ]
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
