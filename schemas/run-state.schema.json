{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunState",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "current_stage",
    "status",
    "completed_gates",
    "failed_gates",
    "retries",
    "spec_review_approved",
    "quality_review_approved"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "task_id": {"type": "string"},
    "current_stage": {"type": "string"},
    "status": {"enum": ["not_started", "in_progress", "blocked", "completed", "failed"]},
    "completed_gates": {"type": "array", "items": {"type": "string"}},
    "failed_gates": {"type": "array", "items": {"type": "string"}},
    "retries": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "spec_review_approved": {"type": "boolean"},
    "quality_review_approved": {"type": "boolean"},
    "final_status": {"enum": ["success", "partial", "failed", "cancelled"]}
  },
  "additionalProperties": false
}