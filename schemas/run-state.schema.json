{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunState",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "current_stage",
    "status",
    "completed_gates",
    "failed_gates",
    "retries",
    "spec_review_approved",
    "quality_review_approved"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "task_id": {
      "type": "string"
    },
    "current_stage": {
      "type": "string",
      "enum": [
        "clarify",
        "plan",
        "execute",
        "spec-review",
        "quality-review",
        "finalize",
        "long-run"
      ]
    },
    "status": {
      "enum": [
        "not_started",
        "in_progress",
        "completed",
        "blocked"
      ]
    },
    "completed_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retries": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "clarify",
          "plan",
          "execute",
          "spec-review",
          "quality-review",
          "finalize",
          "long-run"
        ]
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_task_id": {
      "type": "string"
    },
    "spec_review_approved": {
      "type": "boolean"
    },
    "quality_review_approved": {
      "type": "boolean"
    },
    "final_status": {
      "enum": [
        "success",
        "partial",
        "failed",
        "cancelled"
      ]
    },
    "progress": {
      "type": "object",
      "description": "Progress tracking data injected by execute-intelligence",
      "properties": {
        "total_tasks": { "type": "integer" },
        "done": { "type": "integer" },
        "in_progress": { "type": "integer" },
        "pending": { "type": "integer" },
        "blocked": { "type": "integer" },
        "cancelled": { "type": "integer" },
        "percent": { "type": "number" },
        "per_task": { "type": "object" },
        "next_actionable": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "additionalProperties": false
}
